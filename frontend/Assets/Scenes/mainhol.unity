  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Dear Diary,\n\nI woke up in this place again.\n\nEverything feels wrong
    somehow. The halls are quiet, but not peaceful. It feels like the house is watching
    me. I can still hear the floor creaking even when I stand still.\n\nI tried to
    remember how I got here, but every memory feels blurred, like a dream I was never
    supposed to keep.\n\nSomething tells me I shouldn\u2019t stay here for too long.\n\nI
    need to find a way out.\n\nMother always kept an old key somewhere nearby. I
    remember seeing her hide it inside the hallway drawer, the one near the entrance.
    She never trusted anyone with it.\n\nMaybe it\u2019s still there.\n\nIf I can
    find the key, maybe I can finally leave this place."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
